{
  "name": "mcp-claude-code-conversation-history",
  "version": "0.2.0",
  "description": "MCP server for searching and browsing Claude Code conversation history",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-claude-code-conversation-history": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Stefan-Nitu/mcp-claude-code-conversation-history.git"
  },
  "author": "Stefan Nitu",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "conversation-history",
    "search",
    "bm25"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "check": "bun run typecheck && bun run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "minisearch": "^7.2.0",
    "pino": "^10.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
